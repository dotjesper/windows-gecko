# .editorconfig - Windows gecko project settings

root = true

# Default settings for all files
[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

# PowerShell files
[*.ps1]
indent_size = 4

# PowerShell module/data files
[*.{psd1,psm1}]
indent_size = 4

# JSON configuration files
[*.json]
indent_size = 2

# XML files
[*.xml]
indent_size = 2

# XAML files
[*.xaml]
indent_size = 4

# Markdown files
[*.md]
indent_size = 2
trim_trailing_whitespace = false

# YAML files (GitHub Actions, etc.)
[*.{yml,yaml}]
indent_size = 2

# EditorConfig - https://editorconfig.org
