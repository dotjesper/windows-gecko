{
  "$schema": "./gecko-config.schema.json",
  "metadata": {
    "enabled": true,
    "installBehavior": "USER",
    "guid": "{A82DEE0C-26A0-428A-9ADD-7FC59425F9C5}",
    "title": "Windows gecko-DSC-USER",
    "description": "Windows desired state configuration",
    "url": "",
    "version": "1.5.2.0",
    "date": "2026-02-27",
    "publisher": "dotjesper.com",
    "developer": "Jesper Nielsen"
  },
  "runConditions": {
    "runScriptIn64bitPowerShell": true,
    "requireReboot": false,
    "networkProbe": true,
    "networkProbeCount": 3
  },
  "windowsRegistry": {
    "enabled": true,
    "items": [
      {
        "description": "Hide 'People' from Taskbar",
        "minOSbuild": "",
        "maxOSbuild": "19045",
        "item": "add",
        "root": "HKCU",
        "Path": "Software\\Microsoft\\Windows\\CurrentVersion\\Explorer\\Advanced\\People",
        "Name": "PeopleBand",
        "Type": "REG_DWORD",
        "Value": "0"
      },
      {
        "description": "Hide 'Cortana' icon from Taskbar",
        "minOSbuild": "",
        "maxOSbuild": "19045",
        "item": "add",
        "root": "HKCU",
        "Path": "Software\\Microsoft\\Windows\\CurrentVersion\\Explorer\\Advanced",
        "Name": "ShowCortanaButton",
        "Type": "REG_DWORD",
        "Value": "0"
      },
      {
        "description": "Hide 'News and Interests' icon from Taskbar",
        "minOSbuild": "",
        "maxOSbuild": "19045",
        "item": "add",
        "root": "HKCU",
        "Path": "Software\\Microsoft\\Windows\\CurrentVersion\\Feeds",
        "Name": "ShellFeedsTaskbarViewMode",
        "Type": "REG_DWORD",
        "Value": "2"
      },
      {
        "description": "Hide 'Search' icon from Taskbar",
        "minOSbuild": "30000",
        "maxOSbuild": "",
        "item": "add",
        "root": "HKCU",
        "Path": "Software\\Microsoft\\Windows\\CurrentVersion\\Search",
        "Name": "SearchboxTaskbarMode",
        "Type": "REG_DWORD",
        "Value": "0"
      },
      {
        "description": "Hide 'Copilot (Preview)' icon from Taskbar",
        "minOSbuild": "30000",
        "maxOSbuild": "",
        "item": "add",
        "root": "HKCU",
        "Path": "Software\\Microsoft\\Windows\\CurrentVersion\\Explorer\\Advanced",
        "Name": "ShowCopilotButton",
        "Type": "REG_DWORD",
        "Value": "0"
      },
      {
        "description": "Hide 'Task View Button' icon from Taskbar",
        "minOSbuild": "22000",
        "maxOSbuild": "",
        "item": "add",
        "root": "HKCU",
        "Path": "Software\\Microsoft\\Windows\\CurrentVersion\\Explorer\\Advanced",
        "Name": "ShowTaskViewButton",
        "Type": "REG_DWORD",
        "Value": "0"
      },
      {
        "description": "Hide 'Widgets' icon from Taskbar",
        "minOSbuild": "22000",
        "maxOSbuild": "",
        "item": "add",
        "root": "HKCU",
        "Path": "Software\\Microsoft\\Windows\\CurrentVersion\\Explorer\\Advanced",
        "Name": "TaskbarDa",
        "Type": "REG_DWORD",
        "Value": "0"
      },
      {
        "description": "Hide 'Microsoft Teams Chat' icon from Taskbar",
        "minOSbuild": "22000",
        "maxOSbuild": "22621",
        "item": "add",
        "root": "HKCU",
        "Path": "Software\\Microsoft\\Windows\\CurrentVersion\\Explorer\\Advanced",
        "Name": "TaskbarMn",
        "Type": "REG_DWORD",
        "Value": "0"
      },
      {
        "description": "Disable 'Microsoft Teams Chat' auto-start",
        "minOSbuild": "22000",
        "maxOSbuild": "",
        "item": "add",
        "root": "HKCU",
        "Path": "Software\\Classes\\Local Settings\\Software\\Microsoft\\Windows\\CurrentVersion\\AppModel\\SystemAppData\\MicrosoftTeams_8wekyb3d8bbwe\\TeamsStartupTask",
        "Name": "State",
        "Type": "REG_DWORD",
        "Value": "1"
      },
      {
        "description": "Show Taskbar on all displays",
        "minOSbuild": "22000",
        "maxOSbuild": "",
        "item": "add",
        "root": "HKCU",
        "Path": "Software\\Microsoft\\Windows\\CurrentVersion\\Explorer\\Advanced",
        "Name": "MMTaskbarEnabled",
        "Type": "REG_DWORD",
        "Value": "1"
      },
      {
        "description": "Set Taskbar aligment to Left",
        "minOSbuild": "30000",
        "maxOSbuild": "",
        "item": "add",
        "root": "HKCU",
        "Path": "Software\\Microsoft\\Windows\\CurrentVersion\\Explorer\\Advanced",
        "Name": "TaskbarAl",
        "Type": "REG_DWORD",
        "Value": "0"
      },
      {
        "description": "Show 'This PC' on Desktop",
        "minOSbuild": "30000",
        "maxOSbuild": "",
        "item": "add",
        "root": "HKCU",
        "Path": "Software\\Microsoft\\Windows\\CurrentVersion\\Explorer\\HideDesktopIcons\\NewStartPanel",
        "Name": "{20D04FE0-3AEA-1069-A2D8-08002B30309D}",
        "Type": "REG_DWORD",
        "Value": "0"
      },
      {
        "description": "Show File Explorer and Settings in Start Menu",
        "minOSbuild": "22000",
        "maxOSbuild": "",
        "item": "add",
        "root": "HKCU",
        "Path": "Software\\Microsoft\\Windows\\CurrentVersion\\Start",
        "Name": "VisiblePlaces",
        "Type": "REG_BINARY",
        "Value": "86,08,73,52,aa,51,43,42,9f,7b,27,76,58,46,59,d4,bc,24,8a,14,0c,d6,89,42,a0,80,6e,d9,bb,a2,48,82"
      }
    ]
  },
  "windowsTCR": {
    "enabled": true,
    "settings": {
      "defaultCID": "DEN",
      "copyUserInternationalSettingsToSystem": false,
      "xamlFile": "gecko.xaml"
    },
    "computerNameComparison": {
      "enabled": false,
      "operator": "Contains"
    },
    "locationMarker": {
      "enabled": true,
      "root": "HKLM",
      "path": "SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\OOBE",
      "name": "locationMarker"
    },
    "ntpServer": {
      "enabled": false,
      "peerList": [
        "time.windows.com",
        "time.nist.gov"
      ]
    },
    "configurations": [
      {
        "CID": "DEN",
        "description": "Denmark - Danish culture, Copenhagen timezone",
        "culture": "da-DK",
        "homelocation": 61,
        "timezone": "Romance Standard Time"
      },
      {
        "CID": "FIN",
        "description": "Finland - Finnish culture, Helsinki timezone",
        "culture": "fi-FI",
        "homelocation": 77,
        "timezone": "FLE Standard Time"
      },
      {
        "CID": "NOR",
        "description": "Norway - Norwegian Bokmaal culture, Oslo timezone",
        "culture": "nb-NO",
        "homelocation": 177,
        "timezone": "Romance Standard Time"
      },
      {
        "CID": "SWE",
        "description": "Sweden - Swedish culture, Stockholm timezone",
        "culture": "sv-SE",
        "homelocation": 221,
        "timezone": "W. Europe Standard Time"
      }
    ]
  }
}
